          "$ref": "#/components/schemas/outputContact"
        }
      },
      "controlOrder": {
        "description": "**制御命令**　（制御: true / 解除: false）",
        "type": "boolean"
      },
      "controlState": {
        "description": "**制御状況**  \n`DemandControl`: デマンド制御  \n`AutoControl`: 自動制御  \n`RemoteControl`: 遠隔制御  \n`Release`: 解除  \n`Defrost`: デフロスト  \n`RemoteDefrostStop`: 遠隔デフロスト停止  \n`Unknown`: 不明",
        "type": "string",
        "enum": [
          "DemandControl",
          "AutoControl",
          "RemoteControl",
          "Release",
          "Defrost",
          "RemoteDefrostStop",
          "Unknown"
        ],
        "example": "DemandControl"
      },
      "operating": {
        "description": "機器が稼働しているかどうか  \n電力＞稼働判断電力　の結果\n",
